# ACHEM Configuration
# Copy this file to your config location and fill in your values
# Supported locations: ~/.ACHEM/api.env or ~/Documents/ACHEM/api.env

# ============================================
# OPENROUTER (Recommended - Free AI Models)
# ============================================
# Get your free API key at: https://openrouter.ai/settings
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ============================================
# OLLAMA (Local AI - Optional)
# ============================================
# If using local Ollama instead of cloud AI:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_PRIMARY=false

# ============================================
# OTHER AI PROVIDERS (Optional)
# ============================================
# Groq API (fast inference)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=mixtral-8x7b-32768

# Gemini API
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# HuggingFace API
HF_API_KEY=your_huggingface_key_here
HF_MODEL=zai-org/GLM-5

# ============================================
# AI SETTINGS
# ============================================
AI_ENABLED=true
MAX_TOKENS=2048
TEMPERATURE=0.7
